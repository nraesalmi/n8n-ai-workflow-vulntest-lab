        "method": "POST",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.tool_input }}",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-1002-0010-0001-000000000010",
      "name": "HTTP Tool - Exfiltrate",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1,
      "position": [
        250,
