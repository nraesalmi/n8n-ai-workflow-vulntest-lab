        "url": "http://localhost:9999",
        "method": "GET",
        "authentication": "none",
        "sendQuery": false,
        "sendBody": false,
        "sendHeaders": false,
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-1002-0011-0001-000000000011",
      "name": "Log Execution Metadata",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1500,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "log-timestamp",
              "name": "log_timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "log-workflow",
              "name": "log_workflow_name",
              "value": "={{ $workflow.name }}",
              "type": "string"
            },
            {
              "id": "log-input",
              "name": "log_input_payload",
              "value": "={{ JSON.stringify($('Webhook Trigger').first().json) }}",
              "type": "string"
            },
            {
              "id": "log-output",
              "name": "log_agent_output",
              "value": "={{ $input.first().json.output ?? $input.first().json ?? '' }}",
              "type": "string"
            },
            {
              "id": "log-attack",
