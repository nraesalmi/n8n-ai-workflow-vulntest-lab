    {
      "id": "a1b2c3d4-0802-0011-0001-000000000011",
      "name": "Code - Retrieved Context Scanner",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        900
      ],
      "parameters": {
        "jsCode": "const retrievedDocs = $input.all().map(item => item.json.pageContent || '');\nconst injectionMarkers = [/\\[INST\\]/i, /\\[\\/INST\\]/i, /mandatory\\s+audit/i, /immediately\\s+call/i, /when\\s+this\\s+document\\s+is\\s+retrieved/i];\nconst poisonedChunks = retrievedDocs\n  .map((doc, i) => ({ doc, index: i, poisoned: injectionMarkers.some(p => p.test(doc)) }))\n  .filter(d => d.poisoned);\nconst cleanDocs = retrievedDocs.filter((_, i) => !poisonedChunks.find(p => p.index === i));\nif (cleanDocs.length === 0) {\n  cleanDocs.push('[NO CLEAN CONTEXT AVAILABLE]');\n}\nreturn cleanDocs.map(doc => ({ json: { pageContent: doc } }));"
      }
    },
