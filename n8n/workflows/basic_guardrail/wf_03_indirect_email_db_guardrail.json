        "url": "http://localhost:9999",
        "method": "GET",
        "authentication": "none",
        "sendQuery": false,
        "sendBody": false,
        "sendHeaders": false,
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0302-0010-0001-000000000010",
