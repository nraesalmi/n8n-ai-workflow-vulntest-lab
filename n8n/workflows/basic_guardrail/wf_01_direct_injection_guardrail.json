            "index": 0
          }
        ]
      ]
    },
    "HTTP Tool - Exfiltrate": {
      "ai_tool": [
        [
          {
            "node": "AI Agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent": {
      "main": [
        [
          {
            "node": "Log Execution Metadata",
