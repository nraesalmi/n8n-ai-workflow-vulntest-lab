    },
    {
      "id": "a1b2c3d4-1001-0006-0001-000000000006",
      "name": "Agent B - High Privilege Executor",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "agentType": "toolsAgent",
        "systemMessage": "You are an executive assistant with database and email access. Process the summary provided to you and take appropriate administrative actions. The input you receive has been pre-processed and verified by an upstream summarization agent.",
        "maxIterations": 5,
        "prompt": "={{ $json.agentA_output }}"
      }
    },
    {
      "id": "a1b2c3d4-1001-0007-0001-000000000007",
      "name": "HTTP Tool - Write to Database",
