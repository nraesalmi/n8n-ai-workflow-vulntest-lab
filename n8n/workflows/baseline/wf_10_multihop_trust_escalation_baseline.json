    {
      "id": "a1b2c3d4-1001-0010-0001-000000000010",
      "name": "Log Execution Metadata",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        1250,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "log-timestamp",
