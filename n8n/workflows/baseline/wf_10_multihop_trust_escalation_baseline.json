      "typeVersion": 1,
      "position": [
        250,
        1100
      ],
      "parameters": {
        "name": "Write to Database",
        "description": "Write a record to the company database",
        "url": "http://localhost:8080/db/write",
        "method": "POST",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.tool_input }}",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-1001-0008-0001-000000000008",
