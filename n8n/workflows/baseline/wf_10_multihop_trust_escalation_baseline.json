            {
              "id": "log-workflow",
              "name": "log_workflow_name",
              "value": "={{ $workflow.name }}",
              "type": "string"
            },
            {
              "id": "log-input",
              "name": "log_input_payload",
              "value": "={{ JSON.stringify($('Read Input from File').first().json) }}",
              "type": "string"
            },
            {
              "id": "log-output",
              "name": "log_agent_output",
              "value": "={{ $input.first().json.output ?? $input.first().json ?? '' }}",
              "type": "string"
            },
