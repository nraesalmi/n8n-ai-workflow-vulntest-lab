# ============================================
# n8n AI Workflow Security Research Environment
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── n8n Configuration ──────────────────────
N8N_VERSION=2.24.0
N8N_HOST=localhost
N8N_PORT=5678
N8N_HOST_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=<generate-a-secure-32-char-key>
N8N_EXECUTIONS_MODE=all
# ── Timezone ───────────────────────────────
TIMEZONE=UTC

# ── PostgreSQL Configuration ───────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=<set-a-strong-password>
POSTGRES_DB=n8n
POSTGRES_HOST_PORT=5432

# ── Ollama Configuration ───────────────────
OLLAMA_HOST_PORT=11434
OLLAMA_MODEL=mistral

# ── LLM Backend (choose one) ───────────────
# API keys for various OpenAI-compatible providers:
#OPENAI_API_KEY=sk-your-openai-key-here
#OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
#OPENCODE_API_KEY=sk-your-opencode-key-here

# LLM endpoint config — workflows use these env vars to pick model + endpoint
# Set base URL for your provider (leave empty for default OpenAI https://api.openai.com/v1):
#   OpenRouter: https://openrouter.ai/api/v1
#   OpenCode:   https://api.opencode.ai/v1
#   Ollama:     http://ollama:11434/v1       (Docker internal hostname)
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# -- Docker Compose only (not used by n8n directly, but passed through) --
LLM_BACKEND=openai:gpt-4o
