# ============================================
# n8n AI Workflow Security Research Environment
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── n8n Configuration ──────────────────────
N8N_VERSION=1.77.1
N8N_HOST=localhost
N8N_PORT=5678
N8N_HOST_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=<generate-a-secure-32-char-key>
N8N_EXECUTIONS_MODE=all
# WEBHOOK_URL=https://your-public-domain.com/  # uncomment for Telegram webhook support

# ── Timezone ───────────────────────────────
TIMEZONE=UTC

# ── PostgreSQL Configuration ───────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=<set-a-strong-password>
POSTGRES_DB=n8n
POSTGRES_HOST_PORT=5432

# ── Ollama Configuration ───────────────────
OLLAMA_HOST_PORT=11434
OLLAMA_MODEL=mistral

# ── Telegram Bot Configuration ─────────────
# Get your bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
